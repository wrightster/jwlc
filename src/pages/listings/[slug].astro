---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import BtnArrow from '../../components/BtnArrow.astro';
import EmbedForm from '../../components/EmbedForm.astro';
import ListingCard from '../../components/ListingCard.astro';
import VideoSection from '@jw/shared/components/VideoSection.astro';
import ListingGallery from '@jw/shared/components/ListingGallery.astro';
import { fetchListing, fetchListings, fetchTeam, formatPrice, formatAcres, photoSrc, photoAlt, documentTypeLabel } from '../../lib/api';
import { listingJsonLd, breadcrumbJsonLd } from '@jw/shared/jsonLd';

// Office "JWLC Listing Inquiry" embed form — routes to the listing broker via
// the listing_id forwarded by the widget. Empty string → phone/email fallback.
const listingInquiryToken = 'tjxTU4oNWK0bwRREQlkr76SQkMyTVB3z';

const { slug } = Astro.params;
// Fetch the listing and the "other listings" strip in parallel — they're
// independent, so this saves a round trip. Team is fetched after (it depends on
// the listing's agent names).
const [listing, otherListings] = await Promise.all([
  fetchListing(slug!).catch(() => null),
  fetchListings({ perPage: 4 }).catch(() => []),
]);

if (!listing) {
  return Astro.redirect('/listings');
}

const photos = listing.photos ?? (listing.primary_photo ? [listing.primary_photo] : []);
const imageList = photos.map(p => photoSrc(p, 800)); // VideoSection fallback poster
const heroAlt = photoAlt(photos[0], listing.address);
// Social share card: the listing's primary photo at ~1200px wide (1.91:1-ish).
const ogImage = photos[0] ? photoSrc(photos[0], 1200) : undefined;

// Structured data: RealEstateListing + breadcrumb (validated rich card).
const siteUrl = Astro.site?.href ?? Astro.url.origin;
const jsonLd = [
  listingJsonLd(listing, siteUrl, 'Julie Wright Land Company'),
  breadcrumbJsonLd(listing, siteUrl),
];

const title = listing.marketing_title || listing.address;
const fullAddress = [listing.address, listing.city, listing.state, listing.zip].filter(Boolean).join(', ');

const agentName = listing.agent?.name ?? null;
const agentPhone = listing.agent?.phone ?? null;
const coAgentName = listing.co_agent?.name ?? null;
const coAgentPhone = listing.co_agent?.phone ?? null;
const team = (agentName || coAgentName) ? await fetchTeam().catch(() => []) : [];
const brokerMember = agentName ? team.find((t) => t.name === agentName) : undefined;
const brokerPhoto = photoSrc(brokerMember?.primary_photo, 400);
const coBrokerMember = coAgentName ? team.find((t) => t.name === coAgentName) : undefined;
const coBrokerPhoto = photoSrc(coBrokerMember?.primary_photo, 400);

const relatedListings = otherListings.filter(l => l.slug !== listing.slug).slice(0, 3);

const documents = (listing.documents ?? [])
  .filter((d) => d.url)
  .sort((a, b) => a.sort_order - b.sort_order);

function expiryState(iso: string | null): { label: string; warn: boolean } | null {
  if (!iso) return null;
  const expires = new Date(iso);
  const days = Math.round((expires.getTime() - Date.now()) / (1000 * 60 * 60 * 24));
  if (days < 0) return { label: `Expired ${expires.toLocaleDateString()}`, warn: true };
  if (days <= 30) return { label: `Expires in ${days} days`, warn: true };
  return { label: `Valid through ${expires.toLocaleDateString()}`, warn: false };
}
---

<Layout
  title={`${title} — Julie Wright Land Company`}
  description={listing.description}
  image={ogImage}
  imageAlt={heroAlt}
  jsonLd={jsonLd}
>
  <!-- Back Link -->
  <div class="listing-back-bar">
    <div class="content-wrap py-2">
      <a href="/listings" class="listing-back-link">
        <svg class="listing-back-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
        Back to All Listings
      </a>
    </div>
  </div>

  <!-- Property Details -->
  <section class="listing-detail-section">
    <div class="content-wrap">
      <div class="listing-detail-grid">
        <!-- Main Content -->
        <article class="listing-detail-main">
          <!-- Gallery -->
          <ListingGallery photos={photos} title={title} alt={heroAlt} />

          <!-- Header -->
          <div class="listing-detail-header">
            <div class="listing-badges">
              <span class="listing-status-badge" data-status={listing.status}>
                {listing.status_label}
              </span>
              <span class="listing-county-badge">{listing.county} County</span>
            </div>
            <h1 class="listing-title">{title}</h1>
            {fullAddress && (
              <address class="listing-address-row not-italic">
                <svg class="listing-address-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
                </svg>
                {fullAddress}
              </address>
            )}
          </div>

          <!-- Key Stats -->
          <div class="listing-key-stats">
            <div class="listing-stat-cell">
              <p class="listing-stat-label">Price</p>
              {Number.isNaN(parseFloat(listing.list_price)) ? (
                <p class="listing-stat-value">{formatPrice(listing.list_price)}</p>
              ) : (
                <data class="listing-stat-value block" value={String(parseFloat(listing.list_price))}>{formatPrice(listing.list_price)}</data>
              )}
            </div>
            <div class="listing-stat-cell">
              <p class="listing-stat-label">Acreage</p>
              <p class="listing-stat-value--dark">{formatAcres(listing.lot_size_acres)}</p>
            </div>
            <div class="listing-stat-cell">
              <p class="listing-stat-label">Location</p>
              <p class="listing-stat-value--medium">{listing.city}, {listing.county} County</p>
            </div>
          </div>

          <!-- Description -->
          <h2 class="listing-description-heading">About This Property</h2>
          <div class="listing-description-body">
            {(listing.full_description || listing.description).split('. ').reduce((acc: string[][], sentence, i) => {
              const paragraphIndex = Math.floor(i / 3);
              if (!acc[paragraphIndex]) acc[paragraphIndex] = [];
              acc[paragraphIndex].push(sentence);
              return acc;
            }, []).map((sentences) => (
              <p>{sentences.join('. ')}{sentences[sentences.length - 1]?.endsWith('.') ? '' : '.'}</p>
            ))}
          </div>

          <!-- Documents -->
          {documents.length > 0 && (
            <div class="listing-documents">
              <h2 class="listing-description-heading">Documents</h2>
              <p class="listing-documents-intro">Public materials available for this property — surveys, plats, HOA documents, and more.</p>
              <ul class="listing-documents-list">
                {documents.map((doc) => {
                  const expiry = expiryState(doc.expires_at);
                  return (
                    <li>
                      <a href={doc.url!} target="_blank" rel="noopener noreferrer" class="listing-document-link">
                        <svg class="listing-document-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
                        </svg>
                        <div class="listing-document-body">
                          <div class="listing-document-row">
                            <span class="listing-document-title">{doc.title}</span>
                            <span class="listing-document-pill">{documentTypeLabel(doc.document_type)}</span>
                          </div>
                          {doc.description && <span class="listing-document-desc">{doc.description}</span>}
                          {expiry && (
                            <span class={`listing-document-expiry ${expiry.warn ? 'listing-document-expiry--warn' : ''}`}>
                              {expiry.label}
                            </span>
                          )}
                        </div>
                        <svg class="listing-document-arrow" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
                        </svg>
                      </a>
                    </li>
                  );
                })}
              </ul>
            </div>
          )}

          <!-- Video & Tour -->
          <VideoSection videos={listing.videos} fallbackPoster={imageList[0]} />

          <!-- Directions -->
          {listing.directions && (
            <div class="listing-directions">
              <h2 class="listing-description-heading">Directions</h2>
              <div class="listing-directions-body">
                <svg class="listing-directions-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-6v8.25m.503 3.498 4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 0 0-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0Z" />
                </svg>
                <p>{listing.directions}</p>
              </div>
            </div>
          )}
        </article>

        <!-- Sidebar -->
        <div class="listing-sidebar">
          <div class="listing-contact-card">
            <h3 class="listing-contact-heading">Interested in this property?</h3>
            <p class="listing-contact-desc">Contact the listing broker for details, showings, or to make an offer.</p>

            {agentName && (
              <div class="listing-broker-row">
                {brokerPhoto ? (
                  <img
                    src={brokerPhoto}
                    alt={brokerMember?.primary_photo?.alt ?? agentName}
                    class="listing-broker-photo"
                    loading="lazy"
                  />
                ) : (
                  <div class="listing-broker-avatar">
                    <span class="listing-broker-initials">
                      {agentName.split(' ').map((n: string) => n[0]).join('')}
                    </span>
                  </div>
                )}
                <div>
                  <p class="listing-broker-name">{agentName}</p>
                  <p class="listing-broker-role">Listing Broker</p>
                </div>
              </div>
            )}

            {coAgentName && (
              <div class="listing-broker-row">
                {coBrokerPhoto ? (
                  <img
                    src={coBrokerPhoto}
                    alt={coBrokerMember?.primary_photo?.alt ?? coAgentName}
                    class="listing-broker-photo"
                    loading="lazy"
                  />
                ) : (
                  <div class="listing-broker-avatar">
                    <span class="listing-broker-initials">
                      {coAgentName.split(' ').map((n: string) => n[0]).join('')}
                    </span>
                  </div>
                )}
                <div>
                  <p class="listing-broker-name">{coAgentName}</p>
                  <p class="listing-broker-role">Co-Listing Broker</p>
                </div>
              </div>
            )}

            <div class="listing-contact-actions">
              {listingInquiryToken ? (
                <EmbedForm id="listing-inquiry-form" token={listingInquiryToken} listingId={listing.id} />
              ) : (
                <BtnArrow href="/contact" class="w-full justify-center">Get in Touch</BtnArrow>
              )}
            </div>

            <div class="listing-contact-meta">
              <p class="listing-contact-meta-text">
                Office: <a href="tel:9198475731" class="listing-contact-meta-link">(919) 847-5731</a><br />
                Fax: (919) 847-7182
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Other Listings -->
  <section class="more-listings-section">
    <div class="content-wrap">
      <h2 class="more-listings-heading">More Properties</h2>
      <div class="more-listings-grid">
        {relatedListings.map((other, i) => (
          <ListingCard listing={other} index={i} />
        ))}
      </div>
      <div class="more-listings-cta">
        <a href="/listings" class="btn-secondary text-sm">View All Properties</a>
      </div>
    </div>
  </section>

</Layout>
