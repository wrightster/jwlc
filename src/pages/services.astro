---
import Layout from '../layouts/Layout.astro';
import { services } from '../data/services';
export const prerender = true;
---

<Layout title="Services — Julie Wright Land Company" description="Land brokerage, appraisals, estate planning, 1031 exchanges, timber management, and development services.">
  <!-- Page Header -->
  <section class="page-banner">
    <img src="/FallsLakeTopoContours.svg" class="topo-bg topo-bg--light" alt="" aria-hidden="true" />
    <div class="relative content-wrap">
      <h1 class="page-banner-title">Our Services</h1>
      <p class="page-banner-desc">
        Comprehensive land services backed by 40+ years of experience and relationships across the Triangle.
      </p>
    </div>
  </section>

  <!-- Services Grid -->
  <section class="services-grid-section">
    <div class="content-wrap">
      <div class="services-grid">
        {services.map((service) => (
          <div class="service-card">
            <div class="service-card-accent"></div>
            <div class="service-card-layout">
              <div class="service-card-icon-wrap">
                {service.icon === 'handshake' && (
                  <svg class="service-card-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" />
                  </svg>
                )}
                {service.icon === 'clipboard' && (
                  <svg class="service-card-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25zM6.75 12h.008v.008H6.75V12zm0 3h.008v.008H6.75V15zm0 3h.008v.008H6.75V18z" />
                  </svg>
                )}
                {service.icon === 'map' && (
                  <svg class="service-card-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-6v8.25m.503 3.498l4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 00-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0z" />
                  </svg>
                )}
                {service.icon === 'scroll' && (
                  <svg class="service-card-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
                  </svg>
                )}
                {service.icon === 'arrows' && (
                  <svg class="service-card-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5" />
                  </svg>
                )}
                {service.icon === 'trees' && (
                  <svg class="service-card-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 3L4 14h5.5l-2 7L20 10h-5.5l2-7z" />
                  </svg>
                )}
              </div>
              <div>
                <h3 class="service-card-title">{service.title}</h3>
                <p class="service-card-desc">{service.description}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Networks -->
  <section class="networks-section">
    <div class="content-wrap">
      <div class="networks-header">
        <h2 class="section-heading">Connected to the Right People</h2>
        <p class="networks-desc">
          Over four decades, we've built deep relationships with the professionals who make projects happen.
        </p>
      </div>

      <div class="networks-grid">
        {['Local Custom Builder Network', 'Local Developer Network', 'Local Contractor Network'].map((network) => (
          <div class="network-card">
            <div class="network-icon-wrap">
              <svg class="network-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" />
              </svg>
            </div>
            <h3 class="network-title">{network}</h3>
            <p class="network-desc">Access to trusted professionals through decades of partnership.</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-dark">
    <div class="cta-wrap">
      <h2 class="cta-dark-heading">Inquire About Our Development Portfolio</h2>
      <p class="cta-dark-body">
        Let's discuss how our 40+ years of experience can help with your next project.
      </p>
      <div class="cta-btn-row">
        <a href="/contact" class="btn-primary">Schedule a Consultation</a>
      </div>
    </div>
  </section>
</Layout>
