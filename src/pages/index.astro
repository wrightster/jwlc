---
import Layout from '../layouts/Layout.astro';
import ListingCard from '../components/ListingCard.astro';
import BtnArrow from '../components/BtnArrow.astro';
import { featuredListings } from '../data/listings';
import { testimonials } from '../data/testimonials';
import { services } from '../data/services';
export const prerender = true;
---

<Layout title="Julie Wright Land Company — Finding The Homeplace">

  <!-- ═══════════════════════════════════════════
       HERO
  ════════════════════════════════════════════════ -->
  <section class="hero">
    <img src="/FallTopo_v2.svg" class="topo-bg topo-bg--light" alt="" aria-hidden="true" />
    <div class="relative content-wrap">
      <div class="hero-layout">

        <!-- Left quote -->
        <div class="hero-quote-side-left">
          <div id="hero-quote-left" class="hero-quote-left">
            <p class="hero-quote-text" id="hero-quote-left-text"></p>
            <p class="hero-quote-author" id="hero-quote-left-author"></p>
          </div>
        </div>

        <!-- Center: logo + tagline -->
        <div class="hero-center">
          <p class="hero-eyebrow">Est. 1972 &middot; Raleigh, North Carolina</p>
          <img src="/JWLC_Full_Positive.svg" class="hero-logo" alt="Julie Wright Land Company" />
          <h1 class="hero-tagline">Finding The Homeplace</h1>
        </div>

        <!-- Right quote -->
        <div class="hero-quote-side-right">
          <div id="hero-quote-right" class="hero-quote-right">
            <p class="hero-quote-text" id="hero-quote-right-text"></p>
            <p class="hero-quote-author" id="hero-quote-right-author"></p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <script define:vars={{ testimonials }}>
    const quotes = testimonials;
    const leftWrap  = document.getElementById('hero-quote-left');
    const rightWrap = document.getElementById('hero-quote-right');
    const leftText   = document.getElementById('hero-quote-left-text');
    const leftAuthor = document.getElementById('hero-quote-left-author');
    const rightText   = document.getElementById('hero-quote-right-text');
    const rightAuthor = document.getElementById('hero-quote-right-author');

    let idx = 0;
    let turn = 'left';

    function setQuote(wrap, textEl, authorEl, quote) {
      wrap.style.opacity = '0';
      setTimeout(() => {
        textEl.textContent = '\u201C' + quote.quote + '\u201D';
        authorEl.textContent = '\u2014 ' + quote.author;
        wrap.style.opacity = '1';
      }, 700);
    }

    setQuote(leftWrap,  leftText,  leftAuthor,  quotes[idx++ % quotes.length]);
    setQuote(rightWrap, rightText, rightAuthor, quotes[idx++ % quotes.length]);

    setInterval(() => {
      const quote = quotes[idx++ % quotes.length];
      if (turn === 'left') {
        setQuote(leftWrap, leftText, leftAuthor, quote);
        turn = 'right';
      } else {
        setQuote(rightWrap, rightText, rightAuthor, quote);
        turn = 'left';
      }
    }, 7000);
  </script>

  <!-- ═══════════════════════════════════════════
       FEATURED LISTINGS
  ════════════════════════════════════════════════ -->
  <section class="featured-section">
    <div class="content-wrap">
      <div class="featured-header">
        <div>
          <h2 class="featured-heading">Current Listings</h2>
        </div>
        <BtnArrow href="/listings" variant="secondary">View All</BtnArrow>
      </div>
      <div class="featured-grid">
        {featuredListings.slice(0, 3).map((listing, i) => (
          <ListingCard listing={listing} index={i} />
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       ABOUT + SERVICES
  ════════════════════════════════════════════════ -->
  <section class="home-about-services">
    <div class="content-wrap">
      <div class="home-about-services-grid">

        <!-- About -->
        <div class="home-about-block">
          <h2 class="home-about-heading">
            Rooted in the<br />
            <span class="home-about-accent">Triangle</span> since 1972
          </h2>
          <p class="home-about-body">
            We help buyers, sellers, and investors navigate land — soil, topography, zoning, tax, and estate — with deep local knowledge built over four decades across 8 counties.
          </p>
          <a href="/about" class="home-about-link">
            Meet Our Team
            <svg class="home-link-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>

        <!-- Services -->
        <div class="home-services-block">
          <div class="home-services-grid">
            {services.map((service) => (
              <div>
                <div class="home-service-frame">
                  <img src={service.photo} alt={service.title} class="home-service-img" loading="lazy" />
                </div>
                <p class="home-service-label">{service.title}</p>
              </div>
            ))}
          </div>
          <a href="/services" class="home-services-link">
            All Services
            <svg class="home-link-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       TESTIMONIAL + CTA
  ════════════════════════════════════════════════ -->
  <section class="home-dark-section">
    <img src="/FallTopo_v2.svg" class="topo-bg topo-bg--light" alt="" aria-hidden="true" />
    <div class="home-dark-inner">
      <div class="home-dark-grid">

        <!-- Testimonial -->
        <div>
          <svg class="home-testimonial-icon" viewBox="0 0 24 24" fill="currentColor">
            <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H0z" />
          </svg>
          <blockquote class="home-testimonial-quote">
            "{testimonials[0].quote}"
          </blockquote>
          <footer class="home-testimonial-footer">
            <cite class="home-testimonial-cite">— {testimonials[0].author}</cite>
          </footer>
          <a href="/testimonials" class="home-testimonial-link">
            Read more testimonials
            <svg class="home-link-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>

        <!-- CTA -->
        <div class="home-cta-block">
          <h2 class="home-cta-heading">
            Ready to Find Your<br />
            <span class="home-cta-accent">Perfect Piece of Land?</span>
          </h2>
          <p class="home-cta-body">
            Whether you're buying, selling, or investing — our team has the local knowledge to guide you every step of the way.
          </p>
          <div class="home-cta-actions">
            <a href="/contact" class="btn-primary">Schedule a Free Consultation</a>
            <a href="tel:9198475731" class="home-cta-phone">(919) 847-5731</a>
          </div>
        </div>

      </div>
    </div>
  </section>

</Layout>
