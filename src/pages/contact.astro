---
import Layout from '../layouts/Layout.astro';
export const prerender = true;
---

<Layout title="Contact — Julie Wright Land Company" description="Get in touch with Julie Wright Land Company. Schedule a free consultation about your land needs.">
  <!-- Page Header -->
  <section class="page-banner">
    <div class="content-wrap">
      <h1 class="page-banner-title">Get In Touch</h1>
      <p class="page-banner-desc">
        Whether you're buying, selling, or just exploring options — we're here to help.
      </p>
    </div>
  </section>

  <!-- Contact Content -->
  <section class="contact-section">
    <div class="content-wrap">
      <div class="contact-grid">
        <!-- Contact Form -->
        <div class="contact-form-col">
          <h2 class="contact-form-heading">Schedule a Free Consultation</h2>
          <p class="contact-form-desc">Fill out the form below and we'll get back to you within one business day.</p>

          <div id="jwrg-form"></div>
          <script src="https://office.jwrgnc.com/js/forms.js" data-form-token="zw4zEyoBAO1fjEB7rdHYdv5ka9i11t5A" data-target="#jwrg-form"></script>
          <script>
            const observer = new MutationObserver(() => {
              const btn = document.querySelector('#jwrg-form .jwrg-submit');
              if (btn && !btn.dataset.arrowified) {
                btn.dataset.arrowified = '1';
                const label = btn.textContent.trim();
                btn.classList.add('btn-arrow', 'btn-arrow--primary');
                btn.innerHTML = `
                  <span class="btn-arrow__inner">
                    <span class="btn-arrow__shaft" aria-hidden="true"></span>
                    <svg class="btn-arrow__lcap" viewBox="0 0 324.34 251.68" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
                      <polygon points="251.68,0 0,0 72.66,125.84 0,251.68 251.68,251.68 324.34,125.84"/>
                    </svg>
                    <span class="btn-arrow__body"><span class="btn-arrow__label">${label}</span></span>
                    <svg class="btn-arrow__rcap" viewBox="690.75 0 267.64 251.68" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
                      <polygon points="885.73,0 690.75,0 763.41,125.84 690.75,251.68 885.73,251.68 958.39,125.84"/>
                    </svg>
                  </span>`;
              }
            });
            observer.observe(document.getElementById('jwrg-form'), { childList: true, subtree: true });
          </script>
        </div>

        <!-- Contact Info Sidebar -->
        <div class="contact-sidebar">
          <!-- Office -->
          <div class="sidebar-card">
            <h3 class="sidebar-card-heading">Office</h3>
            <address class="sidebar-address">
              <div class="sidebar-address-row">
                <svg class="sidebar-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
                </svg>
                <div>
                  <p class="sidebar-address-name">Julie Wright Land Company</p>
                  <p>10931 Strickland Rd, Suite 111</p>
                  <p>Raleigh, NC 27615</p>
                </div>
              </div>
              <div class="sidebar-address-row--center">
                <svg class="sidebar-icon--center" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
                </svg>
                <a href="tel:9198475731" class="sidebar-contact-link">(919) 847-5731</a>
              </div>
              <div class="sidebar-address-row--center">
                <svg class="sidebar-icon--center" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
                </svg>
                <span>Fax: (919) 847-7182</span>
              </div>
              <div class="sidebar-address-row--center">
                <svg class="sidebar-icon--center" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
                </svg>
                <a href="mailto:juliannawright@gmail.com" class="sidebar-contact-link">juliannawright@gmail.com</a>
              </div>
            </address>
          </div>

          <!-- Join Mailing List -->
          <div class="sidebar-dark">
            <h3 class="sidebar-dark-heading">Join Our Mailing List</h3>
            <p class="sidebar-dark-desc">Stay updated on new listings and land opportunities across the Triangle.</p>
            <div id="jwrg-mailing-form"></div>
            <script src="https://office.jwrgnc.com/js/forms.js" data-form-token="zIv605tA1VmUNA9twbeE3fr7oBuYcazC" data-target="#jwrg-mailing-form"></script>
            <script>
              const mailingObserver = new MutationObserver(() => {
                const btn = document.querySelector('#jwrg-mailing-form .jwrg-submit');
                if (btn && !btn.dataset.labeled) {
                  btn.dataset.labeled = '1';
                  btn.textContent = 'Subscribe';
                }
              });
              mailingObserver.observe(document.getElementById('jwrg-mailing-form'), { childList: true, subtree: true });
            </script>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Service Area CTA -->
  <section class="cta-red">
    <div class="cta-wrap">
      <h2 class="cta-dark-heading">Serving the Triangle Region</h2>
      <p class="cta-dark-body text-earth-100">We specialize in land across these North Carolina counties.</p>
      <div class="flex flex-wrap justify-center gap-2 mt-8">
        {['Wake', 'Durham', 'Granville', 'Franklin', 'Vance', 'Harnett', 'Nash', 'Chatham'].map((county) => (
          <a href={`/listings?county=${encodeURIComponent(county)}`} class="sidebar-county-tag">{county}</a>
        ))}
      </div>
    </div>
  </section>
</Layout>
