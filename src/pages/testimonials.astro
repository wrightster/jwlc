---
import Layout from '../layouts/Layout.astro';
import BtnArrow from '../components/BtnArrow.astro';
import { testimonials } from '../data/testimonials';
export const prerender = true;
---

<Layout title="Testimonials — Julie Wright Land Company" description="Hear from our clients about their experience working with Julie Wright Land Company.">
  <!-- Page Header -->
  <section class="page-banner">
    <div class="content-wrap">
      <h1 class="page-banner-title">What Our Clients Say</h1>
      <p class="page-banner-desc">
        Real words from real people we've had the privilege of working with over the years.
      </p>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="testimonials-section">
    <div class="testimonials-list-wrap">
      <div class="testimonials-list">
        {testimonials.map((t) => (
          <blockquote class="testimonial-card">
            <div class="testimonial-card-badge">
              <svg class="testimonial-badge-icon" viewBox="0 0 24 24" fill="currentColor">
                <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H0z" />
              </svg>
            </div>
            <p class="testimonial-quote">"{t.quote}"</p>
            <footer class="testimonial-footer">
              <div class="testimonial-avatar">
                <span class="testimonial-initials">{t.author.split(' ').slice(0, 2).map(n => n[0]).join('')}</span>
              </div>
              <cite class="testimonial-cite">
                <span class="testimonial-author">{t.author}</span>
              </cite>
            </footer>
          </blockquote>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-red">
    <div class="cta-wrap">
      <h2 class="cta-dark-heading">Ready to Write Your Own Story?</h2>
      <p class="cta-dark-body text-earth-100">
        Join the hundreds of satisfied clients who have trusted us with their land needs.
      </p>
      <div class="cta-btn-row">
        <BtnArrow href="/contact" variant="inverted">Get Started</BtnArrow>
      </div>
    </div>
  </section>
</Layout>
