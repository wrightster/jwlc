---
// Prerendered shell: the filter chrome + results grid render live from the
// office API in a deferred server island (<ListingsBrowser server:defer>), so
// the banner + CTA paint instantly and the data section streams in behind its
// skeleton. The interactive controller stays on THIS page (the <script> below)
// and initializes when the island's content arrives — scripts placed inside a
// server island run unreliably (withastro/astro#12294), so the DOM-querying
// controller must live here.
export const prerender = true;

import Layout from '../layouts/Layout.astro';
import BtnArrow from '../components/BtnArrow.astro';
import ListingsBrowser from '../components/ListingsBrowser.astro';
---

<Layout title="Listings — Julie Wright Land Company" description="Browse available land, lots, and investment properties across the North Carolina Triangle area.">
  <!-- Page Header -->
  <section class="page-banner">
    <div class="content-wrap">
      <h1 class="page-banner-title">Available Listings</h1>
      <p class="page-banner-desc">
        Land, lots, and investment properties across Wake, Durham, Granville, Franklin, Nash, and Vance counties.
      </p>
    </div>
  </section>

  <!-- Listings Grid -->
  <section class="listings-section">
    <div class="content-wrap">
      <div id="listings-mount">
        <ListingsBrowser server:defer>
          <div slot="fallback" aria-hidden="true">
            <!-- Filter bar placeholder -->
            <div class="h-12 mb-6 rounded-sm bg-earth-100 animate-pulse"></div>
            <!-- Results grid placeholder -->
            <div class="listings-grid" data-view="grid">
              {Array.from({ length: 6 }).map(() => (
                <div class="rounded-sm overflow-hidden ring-1 ring-inset ring-earth-100 bg-white">
                  <div class="aspect-[4/3] bg-earth-100 animate-pulse"></div>
                  <div class="p-4 space-y-2">
                    <div class="h-4 w-1/2 bg-earth-100 rounded animate-pulse"></div>
                    <div class="h-3 w-3/4 bg-earth-100 rounded animate-pulse"></div>
                    <div class="h-3 w-2/3 bg-earth-100 rounded animate-pulse"></div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </ListingsBrowser>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-feature">
    <div class="cta-wrap">
      <h2 class="cta-bold-heading">Don't See What You're Looking For?</h2>
      <p class="cta-bold-body text-earth-100">
        We have access to off-market properties and upcoming listings. Tell us what you need and we'll find it.
      </p>
      <div class="cta-btn-row">
        <BtnArrow href="/contact" variant="inverted">Contact Us</BtnArrow>
      </div>
    </div>
  </section>

  <script>
    // The full controller body lives in initListings(); it is invoked only once
    // the <ListingsBrowser server:defer> island has injected its DOM (see the
    // gating logic after the closing brace).
    function initListings() {
    const items         = document.querySelectorAll('.listing-item');
    const resultsCountEl = document.getElementById('results-count')!;
    const filterCountEl = document.getElementById('filter-active-count')!;

    let currentPage = 1;
    let perPage = 24;

    const sortedPrices = Array.from(items).map(el => parseFloat((el as HTMLElement).dataset.price ?? '0')).filter(p => p > 0).sort((a, b) => b - a);
    const refPrice = sortedPrices.length >= 2 ? sortedPrices[1] : (sortedPrices[0] ?? 0);
    const MAX_PRICE = refPrice > 0 ? Math.floor(refPrice / 50000) * 50000 : 500000;

    const highestAcres = Math.max(...Array.from(items).map(el => parseFloat((el as HTMLElement).dataset.acres ?? '0')));
    const MAX_ACRES = Math.ceil(highestAcres / 2) * 2;

    // ── Custom select state ───────────────────────────────────────────────
    const filterValues: Record<string, string> = { county: 'all', city: 'all', status: 'all' };

    function closeAll(except?: Element) {
      document.querySelectorAll('.custom-select.is-open').forEach(cs => {
        if (cs === except) return;
        cs.classList.remove('is-open');
        cs.querySelector('.custom-select-trigger')!.setAttribute('aria-expanded', 'false');
      });
    }

    document.querySelectorAll('.custom-select').forEach((cs, csIdx) => {
      const trigger  = cs.querySelector('.custom-select-trigger') as HTMLButtonElement;
      const valEl    = cs.querySelector('.custom-select-val') as HTMLElement;
      const filterId = (cs as HTMLElement).dataset.filter!;
      const opts     = Array.from(cs.querySelectorAll('.custom-select-option')) as HTMLElement[];

      // Prepare options for keyboard access
      opts.forEach((opt, i) => {
        opt.id = `cs-${csIdx}-opt-${i}`;
        opt.setAttribute('tabindex', '-1');
        opt.setAttribute('aria-selected', opt.classList.contains('is-selected') ? 'true' : 'false');
      });

      function selectOption(el: HTMLElement) {
        filterValues[filterId] = el.dataset.value ?? 'all';
        valEl.textContent = el.textContent;
        opts.forEach(o => { o.classList.remove('is-selected'); o.setAttribute('aria-selected', 'false'); });
        el.classList.add('is-selected');
        el.setAttribute('aria-selected', 'true');
        applyFiltersReset();
      }

      function openDropdown() {
        cs.classList.add('is-open');
        trigger.setAttribute('aria-expanded', 'true');
      }

      function focusOpt(idx: number) {
        opts[Math.max(0, Math.min(idx, opts.length - 1))].focus();
      }

      // Click: toggle open/close
      trigger.addEventListener('click', e => {
        e.stopPropagation();
        const wasOpen = cs.classList.contains('is-open');
        closeAll();
        if (!wasOpen) openDropdown();
      });

      // Keyboard on trigger: open and move focus into list
      trigger.addEventListener('keydown', e => {
        if (e.key === 'ArrowDown' || e.key === 'ArrowUp' || e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          if (!cs.classList.contains('is-open')) { closeAll(); openDropdown(); }
          const selIdx = opts.findIndex(o => o.classList.contains('is-selected'));
          focusOpt(selIdx >= 0 ? selIdx : 0);
        }
      });

      // Keyboard + click on options
      opts.forEach((opt, i) => {
        opt.addEventListener('click', e => { e.stopPropagation(); selectOption(opt); });
        opt.addEventListener('dblclick', e => { e.stopPropagation(); closeAll(); });
        opt.addEventListener('keydown', e => {
          switch (e.key) {
            case 'ArrowDown': e.preventDefault(); focusOpt(i + 1 < opts.length ? i + 1 : 0); break;
            case 'ArrowUp':   e.preventDefault(); focusOpt(i > 0 ? i - 1 : opts.length - 1); break;
            case 'Home':      e.preventDefault(); focusOpt(0); break;
            case 'End':       e.preventDefault(); focusOpt(opts.length - 1); break;
            case 'Enter':
            case ' ':         e.preventDefault(); selectOption(opt); closeAll(); trigger.focus(); break;
            case 'Escape':
            case 'Tab':       e.preventDefault(); closeAll(); trigger.focus(); break;
          }
        });
      });
    });

    // Outside click closes all
    document.addEventListener('click', () => closeAll());

    // Scroll closes all
    window.addEventListener('scroll', () => closeAll(), { passive: true });

    // ── Filter logic ──────────────────────────────────────────────────────
    let priceMin = 0, priceMax = MAX_PRICE;
    let acresMin = 0, acresMax = MAX_ACRES;

    // Status values map to URL shorthand
    const statusToShort: Record<string, string> = {
      active: 'a', coming_soon: 'c', pending: 'p', under_contract: 'u', sold: 's'
    };
    const shortToStatus: Record<string, string> = {
      a: 'active', c: 'coming_soon', p: 'pending', u: 'under_contract', s: 'sold'
    };

    function updateURL() {
      const params = new URLSearchParams();
      if (filterValues.county !== 'all') params.set('county', filterValues.county);
      if (filterValues.city   !== 'all') params.set('city',   filterValues.city);
      if (filterValues.status !== 'all') params.set('status', statusToShort[filterValues.status] ?? filterValues.status);
      if (priceMin > 0 || priceMax < MAX_PRICE)   params.set('price', `${priceMin / 1000}-${priceMax / 1000}`);
      if (acresMin > 0 || acresMax < MAX_ACRES)   params.set('acres', `${acresMin}-${acresMax}`);
      if (perPage !== 24)    params.set('pp',   String(perPage));
      if (currentPage > 1)   params.set('page', String(currentPage));
      const qs = params.toString();
      history.replaceState(null, '', qs ? '?' + qs : window.location.pathname);
    }

    function applyFilters() {
      const matched: HTMLElement[] = [];
      items.forEach(item => {
        const el        = item as HTMLElement;
        const itemPrice = parseFloat(el.dataset.price ?? '0');
        const itemAcres = parseFloat(el.dataset.acres ?? '0');
        const countyOk  = filterValues.county === 'all' || el.dataset.county === filterValues.county;
        const cityOk    = filterValues.city   === 'all' || el.dataset.city   === filterValues.city;
        const statusOk  = filterValues.status === 'all' || el.dataset.status === filterValues.status;
        const priceOk   = itemPrice >= priceMin && (priceMax >= MAX_PRICE || itemPrice <= priceMax);
        const acresOk   = itemAcres >= acresMin && (acresMax >= MAX_ACRES  || itemAcres <= acresMax);
        el.style.display = 'none';
        if (countyOk && cityOk && statusOk && priceOk && acresOk) matched.push(el);
      });

      const totalPages = Math.max(1, Math.ceil(matched.length / perPage));
      if (currentPage > totalPages) currentPage = totalPages;

      const start = (currentPage - 1) * perPage;
      const end   = Math.min(start + perPage, matched.length);
      matched.slice(start, end).forEach(el => el.style.display = '');

      updateResultsCount(matched.length, start, end);
      updatePagination(totalPages);
      updateURL();
      updateFilterCount();
    }

    function applyFiltersReset() {
      currentPage = 1;
      applyFilters();
    }

    function updateResultsCount(total: number, start: number, end: number) {
      if (total === 0) {
        resultsCountEl.innerHTML = 'Showing <span class="results-count-val">0</span> properties';
      } else if (total <= perPage) {
        resultsCountEl.innerHTML = `Showing <span class="results-count-val">${total}</span> propert${total === 1 ? 'y' : 'ies'}`;
      } else {
        resultsCountEl.innerHTML = `Showing <span class="results-count-val">${start + 1}–${end}</span> of ${total} properties`;
      }
    }

    function updatePagination(totalPages: number) {
      const paginationEl = document.getElementById('pagination') as HTMLElement;
      const prevBtn      = document.getElementById('pg-prev')    as HTMLButtonElement;
      const nextBtn      = document.getElementById('pg-next')    as HTMLButtonElement;
      const infoEl       = document.getElementById('pg-info')    as HTMLElement;
      paginationEl.style.display = totalPages <= 1 ? 'none' : '';
      prevBtn.disabled = currentPage <= 1;
      nextBtn.disabled = currentPage >= totalPages;
      infoEl.textContent = `Page ${currentPage} of ${totalPages}`;
    }

    function updateFilterCount() {
      let active = 0;
      if (filterValues.county !== 'all') active++;
      if (filterValues.city   !== 'all') active++;
      if (filterValues.status !== 'all') active++;
      if (priceMin > 0 || priceMax < MAX_PRICE) active++;
      if (acresMin > 0 || acresMax < MAX_ACRES)  active++;
      filterCountEl.textContent = active > 0 ? String(active) : '';
      filterCountEl.classList.toggle('is-visible', active > 0);
    }

    // ── Range sliders ─────────────────────────────────────────────────────
    function updateFill(fill: HTMLElement, minEl: HTMLInputElement, maxEl: HTMLInputElement, max: number) {
      const lo = (parseFloat(minEl.value) / max) * 100;
      const hi = (parseFloat(maxEl.value) / max) * 100;
      fill.style.left  = lo + '%';
      fill.style.width = (hi - lo) + '%';
    }

    const priceMinEl  = document.getElementById('price-min')         as HTMLInputElement;
    const priceMaxEl  = document.getElementById('price-max')         as HTMLInputElement;
    const priceFill   = document.getElementById('price-fill')        as HTMLElement;
    const priceMinLbl = document.getElementById('price-min-display') as HTMLElement;
    const priceMaxLbl = document.getElementById('price-max-display') as HTMLElement;

    priceMinEl.max = String(MAX_PRICE);
    priceMaxEl.max = String(MAX_PRICE);
    priceMaxEl.value = String(MAX_PRICE);
    priceMaxLbl.textContent = '$' + MAX_PRICE.toLocaleString() + '+';

    function onPriceChange(this: HTMLInputElement) {
      let lo = parseFloat(priceMinEl.value), hi = parseFloat(priceMaxEl.value);
      if (this === priceMinEl && lo >= hi) { lo = hi - 10000; priceMinEl.value = String(lo); }
      if (this === priceMaxEl && hi <= lo) { hi = lo + 10000; priceMaxEl.value = String(hi); }
      priceMin = lo; priceMax = hi;
      priceMinLbl.textContent = '$' + lo.toLocaleString();
      priceMaxLbl.textContent = hi >= MAX_PRICE ? '$' + MAX_PRICE.toLocaleString() + '+' : '$' + hi.toLocaleString();
      updateFill(priceFill, priceMinEl, priceMaxEl, MAX_PRICE);
      applyFiltersReset();
    }
    priceMinEl.addEventListener('input', onPriceChange);
    priceMaxEl.addEventListener('input', onPriceChange);
    updateFill(priceFill, priceMinEl, priceMaxEl, MAX_PRICE);

    const acresMinEl  = document.getElementById('acres-min')         as HTMLInputElement;
    const acresMaxEl  = document.getElementById('acres-max')         as HTMLInputElement;
    const acresFill   = document.getElementById('acres-fill')        as HTMLElement;
    const acresMinLbl = document.getElementById('acres-min-display') as HTMLElement;
    const acresMaxLbl = document.getElementById('acres-max-display') as HTMLElement;

    acresMinEl.max = String(MAX_ACRES);
    acresMaxEl.max = String(MAX_ACRES);
    acresMaxEl.value = String(MAX_ACRES);
    acresMaxLbl.textContent = MAX_ACRES + '+ ac';

    function fmtAcres(v: number) { return String(v); }

    function onAcresChange(this: HTMLInputElement) {
      let lo = parseFloat(acresMinEl.value), hi = parseFloat(acresMaxEl.value);
      if (this === acresMinEl && lo >= hi) { lo = hi - 1; acresMinEl.value = String(lo); }
      if (this === acresMaxEl && hi <= lo) { hi = lo + 1; acresMaxEl.value = String(hi); }
      acresMin = lo; acresMax = hi;
      acresMinLbl.textContent = fmtAcres(lo) + ' ac';
      acresMaxLbl.textContent = (hi >= MAX_ACRES ? MAX_ACRES + '+' : fmtAcres(hi)) + ' ac';
      updateFill(acresFill, acresMinEl, acresMaxEl, MAX_ACRES);
      applyFiltersReset();
    }
    acresMinEl.addEventListener('input', onAcresChange);
    acresMaxEl.addEventListener('input', onAcresChange);
    updateFill(acresFill, acresMinEl, acresMaxEl, MAX_ACRES);

    // ── Per-page selector ─────────────────────────────────────────────────
    const perPageBtns = document.querySelectorAll('.per-page-btn');

    function setPerPage(n: number) {
      perPage = n;
      perPageBtns.forEach(btn => btn.classList.toggle('is-active', parseInt((btn as HTMLElement).dataset.pp ?? '0') === n));
      localStorage.setItem('jwlc-per-page', String(n));
    }

    perPageBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        setPerPage(parseInt((btn as HTMLElement).dataset.pp ?? '24'));
        applyFiltersReset();
      });
    });

    const savedPP = parseInt(localStorage.getItem('jwlc-per-page') ?? '24');
    if ([12, 24, 48, 96].includes(savedPP)) setPerPage(savedPP);

    // ── Pagination buttons ────────────────────────────────────────────────
    document.getElementById('pg-prev')?.addEventListener('click', () => {
      if (currentPage > 1) { currentPage--; applyFilters(); window.scrollTo({ top: 0, behavior: 'smooth' }); }
    });
    document.getElementById('pg-next')?.addEventListener('click', () => {
      currentPage++; applyFilters(); window.scrollTo({ top: 0, behavior: 'smooth' });
    });

    // ── Initialize from URL params (runs after all vars are ready) ────────
    (function initFromURL() {
      const params = new URLSearchParams(window.location.search);
      if (!params.toString()) return;

      // Dropdowns
      const paramMap: Array<[string, string]> = [['county', 'county'], ['city', 'city'], ['status', 'status']];
      paramMap.forEach(([param, filterId]) => {
        const raw = params.get(param);
        if (!raw) return;
        const val = filterId === 'status' ? (shortToStatus[raw] ?? raw) : raw;
        const cs = document.querySelector(`.custom-select[data-filter="${filterId}"]`);
        if (!cs) return;
        const valEl   = cs.querySelector('.custom-select-val') as HTMLElement;
        const options = cs.querySelectorAll('.custom-select-option');
        options.forEach(opt => {
          const el = opt as HTMLElement;
          const isMatch = el.dataset.value === val;
          el.classList.toggle('is-selected', isMatch);
          el.setAttribute('aria-selected', isMatch ? 'true' : 'false');
          if (isMatch) valEl.textContent = el.textContent;
        });
        filterValues[filterId] = val;
      });

      // Price sliders
      const priceParam = params.get('price');
      if (priceParam) {
        const [pLo, pHi] = priceParam.split('-').map(v => parseFloat(v) * 1000);
        if (!isNaN(pLo)) { priceMin = pLo; priceMinEl.value = String(pLo); priceMinLbl.textContent = '$' + pLo.toLocaleString(); }
        if (!isNaN(pHi)) { priceMax = pHi; priceMaxEl.value = String(pHi); priceMaxLbl.textContent = '$' + pHi.toLocaleString(); }
        updateFill(priceFill, priceMinEl, priceMaxEl, MAX_PRICE);
      }

      // Acres sliders
      const acresParam = params.get('acres');
      if (acresParam) {
        const [aLo, aHi] = acresParam.split('-').map(v => parseFloat(v));
        if (!isNaN(aLo)) { acresMin = aLo; acresMinEl.value = String(aLo); acresMinLbl.textContent = fmtAcres(aLo) + ' ac'; }
        if (!isNaN(aHi)) { acresMax = aHi; acresMaxEl.value = String(aHi); acresMaxLbl.textContent = fmtAcres(aHi) + ' ac'; }
        updateFill(acresFill, acresMinEl, acresMaxEl, MAX_ACRES);
      }

      // Per-page and page
      const ppParam = parseInt(params.get('pp') ?? '0');
      if ([12, 24, 48, 96].includes(ppParam)) setPerPage(ppParam);
      const pageParam = parseInt(params.get('page') ?? '1');
      if (pageParam > 1) currentPage = pageParam;

      applyFilters();
    })();

    // ── Filter collapse toggle ────────────────────────────────────────────
    const filterBar     = document.getElementById('filter-bar')!;
    const filterToggle  = document.getElementById('filter-toggle') as HTMLButtonElement;
    const filterInner   = document.querySelector('.filter-collapse-inner') as HTMLElement;

    function setFilterCollapsed(collapsed: boolean, save = true, animate = true) {
      filterBar.classList.toggle('is-collapsed', collapsed);
      filterToggle.setAttribute('aria-expanded', String(!collapsed));
      if (collapsed) {
        if (animate) {
          filterInner.style.height = filterInner.scrollHeight + 'px';
          filterInner.getBoundingClientRect(); // force reflow
        }
        filterInner.style.overflow = 'hidden';
        filterInner.style.height = '0';
      } else {
        filterInner.style.overflow = 'hidden';
        filterInner.style.height = filterInner.scrollHeight + 'px';
        if (animate) {
          filterInner.addEventListener('transitionend', () => {
            filterInner.style.height = '';
            filterInner.style.overflow = '';
          }, { once: true });
        } else {
          filterInner.style.height = '';
          filterInner.style.overflow = '';
        }
      }
      if (save) localStorage.setItem('jwlc-filters-open', collapsed ? '0' : '1');
    }

    const savedOpen = localStorage.getItem('jwlc-filters-open');
    setFilterCollapsed(savedOpen !== '1', false, false);

    filterToggle.addEventListener('click', () => {
      setFilterCollapsed(!filterBar.classList.contains('is-collapsed'));
    });

    // ── View toggle ───────────────────────────────────────────────────────
    const grid     = document.getElementById('listings-grid') as HTMLElement;
    const btnGrid  = document.getElementById('btn-grid')  as HTMLButtonElement;
    const btnList  = document.getElementById('btn-list')  as HTMLButtonElement;

    function setView(mode: 'grid' | 'list') {
      grid.dataset.view = mode;
      btnGrid.classList.toggle('is-active', mode === 'grid');
      btnList.classList.toggle('is-active', mode === 'list');
      document.querySelectorAll<HTMLElement>('.listing-card').forEach(el => el.setAttribute('aria-hidden', mode === 'list' ? 'true' : 'false'));
      document.querySelectorAll<HTMLElement>('.listing-row').forEach(el => el.setAttribute('aria-hidden', mode === 'grid' ? 'true' : 'false'));
      localStorage.setItem('jwlc-view', mode);
    }

    // Default: list on mobile, grid on desktop — unless the user has saved a preference
    const savedView = localStorage.getItem('jwlc-view') as 'grid' | 'list' | null;
    setView(savedView ?? (window.innerWidth < 1024 ? 'list' : 'grid'));

    btnGrid.addEventListener('click', () => setView('grid'));
    btnList.addEventListener('click', () => setView('list'));
    }

    // The interactive controller lives on this (prerendered) page, but the DOM
    // it drives is rendered by the <ListingsBrowser server:defer> island and
    // injected after page load. Wait for the island's `data-listings-ready`
    // sentinel before wiring up — scripts placed INSIDE a server island run
    // unreliably (withastro/astro#12294), so the controller stays here and
    // observes the mount instead. `ok` means the grid rendered; `error` means
    // the island rendered its failure state (nothing to wire up).
    const mount = document.getElementById('listings-mount');
    function tryInit(): boolean {
      const sentinel = mount?.querySelector('[data-listings-ready]');
      if (!sentinel) return false; // island not resolved yet — keep waiting
      if (sentinel.getAttribute('data-listings-ready') === 'ok') initListings();
      return true; // resolved (ok or error) — stop waiting
    }
    if (mount && !tryInit()) {
      const mo = new MutationObserver(() => { if (tryInit()) mo.disconnect(); });
      mo.observe(mount, { childList: true, subtree: true });
    }
  </script>
</Layout>
