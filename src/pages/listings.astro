---
import Layout from '../layouts/Layout.astro';
import ListingCard from '../components/ListingCard.astro';
import { listings } from '../data/listings';
export const prerender = true;

function parsePrice(price: string): number {
  const match = price.replace(/[$,]/g, '').match(/[\d.]+/);
  return match ? parseFloat(match[0]) : 0;
}
function parseAcres(acreage: string): number {
  const match = acreage.match(/[\d.]+/);
  return match ? parseFloat(match[0]) : 0;
}
---

<Layout title="Listings — Julie Wright Land Company" description="Browse available land, lots, and investment properties across the North Carolina Triangle area.">
  <!-- Page Header -->
  <section class="page-banner">
    <img src="/FallsLakeTopoContours.svg" class="topo-bg topo-bg--light" alt="" aria-hidden="true" />
    <div class="relative content-wrap">
      <h1 class="page-banner-title">Available Listings</h1>
      <p class="page-banner-desc">
        Land, lots, and investment properties across Wake, Durham, Granville, Franklin, Nash, and Vance counties.
      </p>
    </div>
  </section>

  <!-- Listings Grid -->
  <section class="listings-section">
    <div class="content-wrap">
      <!-- Filter bar -->
      <div class="filter-bar">
        <!-- County filters -->
        <div class="filter-county-row">
          <span class="filter-label">Filter by county:</span>
          <button class="county-filter active" data-county="all">All</button>
          {[...new Set(listings.map(l => l.county))].sort().map((county) => (
            <button class="county-filter" data-county={county}>{county}</button>
          ))}
        </div>

        <!-- Range sliders -->
        <div class="filter-range-row">
          <!-- Price -->
          <div>
            <p class="filter-range-label">Price Range</p>
            <div class="range-slider">
              <div class="range-track"><div class="range-fill" id="price-fill"></div></div>
              <input type="range" id="price-min" min="0" max="500000" step="5000" value="0" class="range-input" />
              <input type="range" id="price-max" min="0" max="500000" step="5000" value="500000" class="range-input" />
            </div>
            <div class="filter-range-display">
              <div class="filter-range-side filter-range-side--left"><span id="price-min-display" class="filter-range-val">$0</span></div>
              <span class="filter-range-sep">to</span>
              <div class="filter-range-side filter-range-side--right"><span id="price-max-display" class="filter-range-val">$500,000+</span></div>
            </div>
          </div>

          <!-- Acreage -->
          <div>
            <p class="filter-range-label">Acreage</p>
            <div class="range-slider">
              <div class="range-track"><div class="range-fill" id="acres-fill"></div></div>
              <input type="range" id="acres-min" min="0" max="50" step="0.5" value="0" class="range-input" />
              <input type="range" id="acres-max" min="0" max="50" step="0.5" value="50" class="range-input" />
            </div>
            <div class="filter-range-display">
              <div class="filter-range-side filter-range-side--left"><span id="acres-min-display" class="filter-range-val">0</span></div>
              <span class="filter-range-sep">to</span>
              <div class="filter-range-side filter-range-side--right"><span id="acres-max-display" class="filter-range-val">50+ acres</span></div>
            </div>
          </div>
        </div>
      </div>

      <!-- Results count -->
      <p class="results-count">
        Showing <span id="count" class="results-count-val">{listings.length}</span> properties
      </p>

      <!-- Grid -->
      <div class="listings-grid" id="listings-grid">
        {listings.map((listing, i) => (
          <div class="listing-item" data-county={listing.county} data-price={parsePrice(listing.price)} data-acres={parseAcres(listing.acreage)} id={listing.id}>
            <ListingCard listing={listing} index={i} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-light">
    <div class="cta-wrap">
      <h2 class="cta-light-heading">Don't See What You're Looking For?</h2>
      <p class="cta-light-body">
        We have access to off-market properties and upcoming listings. Tell us what you need and we'll find it.
      </p>
      <div class="cta-btn-row">
        <a href="/contact" class="btn-primary">Contact Us</a>
      </div>
    </div>
  </section>

  <script>
    const MAX_PRICE = 500000;
    const MAX_ACRES = 50;

    const filters = document.querySelectorAll('.county-filter');
    const items = document.querySelectorAll('.listing-item');
    const countEl = document.getElementById('count');

    let activeCounty = 'all';
    let priceMin = 0, priceMax = MAX_PRICE;
    let acresMin = 0, acresMax = MAX_ACRES;

    function applyFilters() {
      let visible = 0;
      items.forEach(item => {
        const el = item as HTMLElement;
        const itemPrice = parseFloat(el.dataset.price ?? '0');
        const itemAcres = parseFloat(el.dataset.acres ?? '0');
        const countyOk = activeCounty === 'all' || el.dataset.county === activeCounty;
        const priceOk  = itemPrice >= priceMin && (priceMax >= MAX_PRICE || itemPrice <= priceMax);
        const acresOk  = itemAcres >= acresMin && (acresMax >= MAX_ACRES || itemAcres <= acresMax);
        el.style.display = (countyOk && priceOk && acresOk) ? '' : 'none';
        if (countyOk && priceOk && acresOk) visible++;
      });
      if (countEl) countEl.textContent = String(visible);
    }

    filters.forEach(btn => {
      btn.addEventListener('click', () => {
        filters.forEach(f => f.classList.remove('active'));
        btn.classList.add('active');
        activeCounty = (btn as HTMLElement).dataset.county ?? 'all';
        applyFilters();
      });
    });

    function updateFill(fill: HTMLElement, minInput: HTMLInputElement, maxInput: HTMLInputElement, max: number) {
      const lo = (parseFloat(minInput.value) / max) * 100;
      const hi = (parseFloat(maxInput.value) / max) * 100;
      fill.style.left  = lo + '%';
      fill.style.width = (hi - lo) + '%';
    }

    function formatPrice(v: number) {
      return '$' + v.toLocaleString();
    }

    const priceMinEl  = document.getElementById('price-min') as HTMLInputElement;
    const priceMaxEl  = document.getElementById('price-max') as HTMLInputElement;
    const priceFill   = document.getElementById('price-fill') as HTMLElement;
    const priceMinLbl = document.getElementById('price-min-display') as HTMLElement;
    const priceMaxLbl = document.getElementById('price-max-display') as HTMLElement;

    function onPriceChange() {
      let lo = parseFloat(priceMinEl.value);
      let hi = parseFloat(priceMaxEl.value);
      if (lo > hi) { if (this === priceMinEl) { lo = hi; priceMinEl.value = String(lo); } else { hi = lo; priceMaxEl.value = String(hi); } }
      priceMin = lo; priceMax = hi;
      priceMinLbl.textContent = formatPrice(lo);
      priceMaxLbl.textContent = hi >= MAX_PRICE ? formatPrice(MAX_PRICE) + '+' : formatPrice(hi);
      updateFill(priceFill, priceMinEl, priceMaxEl, MAX_PRICE);
      applyFilters();
    }
    priceMinEl.addEventListener('input', onPriceChange);
    priceMaxEl.addEventListener('input', onPriceChange);
    updateFill(priceFill, priceMinEl, priceMaxEl, MAX_PRICE);

    const acresMinEl  = document.getElementById('acres-min') as HTMLInputElement;
    const acresMaxEl  = document.getElementById('acres-max') as HTMLInputElement;
    const acresFill   = document.getElementById('acres-fill') as HTMLElement;
    const acresMinLbl = document.getElementById('acres-min-display') as HTMLElement;
    const acresMaxLbl = document.getElementById('acres-max-display') as HTMLElement;

    function fmtAcres(v: number) {
      return v % 1 === 0 ? String(v) : v.toFixed(1);
    }

    function onAcresChange() {
      let lo = parseFloat(acresMinEl.value);
      let hi = parseFloat(acresMaxEl.value);
      if (lo > hi) { if (this === acresMinEl) { lo = hi; acresMinEl.value = String(lo); } else { hi = lo; acresMaxEl.value = String(hi); } }
      acresMin = lo; acresMax = hi;
      acresMinLbl.textContent = fmtAcres(lo) + ' acres';
      acresMaxLbl.textContent = (hi >= MAX_ACRES ? MAX_ACRES + '+' : fmtAcres(hi)) + ' acres';
      updateFill(acresFill, acresMinEl, acresMaxEl, MAX_ACRES);
      applyFilters();
    }
    acresMinEl.addEventListener('input', onAcresChange);
    acresMaxEl.addEventListener('input', onAcresChange);
    updateFill(acresFill, acresMinEl, acresMaxEl, MAX_ACRES);
  </script>
</Layout>
