---
import Layout from '../layouts/Layout.astro';
import BtnArrow from '../components/BtnArrow.astro';
import TeamGrid from '../components/TeamGrid.astro';
export const prerender = true;

// The team grid renders in a deferred server island (<TeamGrid server:defer>)
// rather than a build-time fetch — the shell stays static/instant AND the team
// reflects office changes without a site rebuild. The island is server-rendered
// on demand.
---

<Layout title="About Us — Julie Wright Land Company" description="Meet the experienced team behind Julie Wright Land Company. Over 50 years of Triangle area land expertise.">
  <!-- Page Header -->
  <section class="page-banner">
    <div class="content-wrap">
      <h1 class="page-banner-title">About Us</h1>
      <p class="page-banner-desc">
        A dedicated team of brokers and developers with deep roots in North Carolina's Triangle region.
      </p>
    </div>
  </section>

  <!-- Company Story -->
  <section class="story-section">
    <div class="content-wrap">
      <div class="max-w-3xl mx-auto">
        <h2 class="section-heading text-center">Five Decades of<br />Land Expertise</h2>
        <div class="story-body">
          <p>
            Julie Wright Land Company has helped people buy and sell land across the Triangle for more than 50 years. Julie started the company in 1972 after leaving a career in nursing, and the idea behind it was straightforward: find the right piece of land for the right buyer, or find the right use for a piece of land somebody already owns. That has not really changed.
          </p>
          <p>
            What has changed is how much there is to know. Soil and topography, zoning rules and road access, taxes and estate planning all factor in, and we work through them with you so the decision feels clear by the end. Our brokers cover eight counties across central North Carolina, including Wake, Durham, Granville, Franklin, Vance, Harnett, Nash, and Chatham, and most of what we know about these communities came from spending decades in them.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Team -->
  <section class="team-section" id="team">
    <div class="content-wrap">
      <div class="team-header">
        <h2 class="section-heading">Meet Our Brokers</h2>
      </div>

      <TeamGrid server:defer>
        <div slot="fallback" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6" aria-hidden="true">
          {Array.from({ length: 8 }).map(() => (
            <div class="bg-white rounded-sm ring-1 ring-inset ring-earth-100 overflow-hidden">
              <div class="aspect-square bg-earth-100 animate-pulse"></div>
              <div class="p-4 space-y-2">
                <div class="h-4 w-2/3 bg-earth-100 rounded animate-pulse"></div>
                <div class="h-3 w-1/2 bg-earth-100 rounded animate-pulse"></div>
              </div>
            </div>
          ))}
        </div>
      </TeamGrid>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-feature">
    <div class="cta-wrap">
      <h2 class="cta-bold-heading">Work With Our Team</h2>
      <p class="cta-bold-body text-earth-100">
        Ready to discuss your land needs? We'd love to hear from you.
      </p>
      <div class="cta-btn-row">
        <BtnArrow href="/contact" variant="inverted">Get in Touch</BtnArrow>
      </div>
    </div>
  </section>
</Layout>
