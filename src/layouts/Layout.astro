---
import '../styles/global.css';
import FontSwitcher from '../components/FontSwitcher.astro';
import Seo from '@jw/shared/components/Seo.astro';
import { brokerageJsonLd } from '@jw/shared/jsonLd';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  ogType?: string;
  /** Page-specific JSON-LD (e.g. RealEstateListing + breadcrumb); merged with
   *  the sitewide brokerage block emitted on every page. */
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const SITE_NAME = 'Julie Wright Land Company';

const {
  title = SITE_NAME,
  description = 'Specializing in Raleigh, NC and Triangle Area land brokerage, sales, and investment properties for over 50 years.',
  image,
  imageAlt,
  ogType = 'website',
  jsonLd,
} = Astro.props;

const currentPath = Astro.url.pathname;
const canonicalUrl = `${Astro.url.origin}${Astro.url.pathname}`;

// Social share image. Pages pass a root-relative path or an absolute URL
// (listing detail passes the listing's primary photo); both are resolved to an
// absolute URL because social crawlers reject relative paths. Falls back to the
// branded 1200×630 card. Rename the default file (not just its contents) to bust
// LinkedIn's ~7-day preview cache.
const DEFAULT_OG_IMAGE = '/images/og-default.png';
const ogImageUrl = new URL(image ?? DEFAULT_OG_IMAGE, Astro.site ?? Astro.url).href;

// Sitewide brokerage identity (one RealEstateAgent block on every page). Uses
// the canonical production host regardless of environment so the identity is
// stable. Page-provided JSON-LD is appended after it.
const brokerage = brokerageJsonLd({
  name: 'Julie Wright Land Company LLC',
  url: 'https://juliewrightlandcompany.com',
  licenseNumber: 'C29157',
  street: '10931 Strickland Rd, Ste 111',
  city: 'Raleigh',
  region: 'NC',
  postalCode: '27615-2085',
  areaServed: [
    'Wake County, NC',
    'Granville County, NC',
    'Franklin County, NC',
    'Johnston County, NC',
    'Durham County, NC',
  ],
});
const pageJsonLd = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
const jsonLdBlocks = [brokerage, ...pageJsonLd];

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/listings', label: 'Listings' },
  { href: '/services', label: 'Services' },
  { href: '/testimonials', label: 'Testimonials' },
  { href: '/contact', label: 'Contact' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/JWLC_Icon_Inset.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <!-- Warm the connection to the office host up front: every listing and team
         photo is served from office.jwrgnc.com, so opening the TLS handshake
         early shaves it off the first image request (the deferred island grids
         paint their images as soon as the fragment arrives). dns-prefetch is the
         fallback for browsers that ignore preconnect. -->
    <link rel="preconnect" href="https://office.jwrgnc.com" crossorigin />
    <link rel="dns-prefetch" href="https://office.jwrgnc.com" />
    <Seo
      title={title}
      description={description}
      canonicalUrl={canonicalUrl}
      siteName={SITE_NAME}
      image={ogImageUrl}
      imageAlt={imageAlt}
      ogType={ogType}
      jsonLd={jsonLdBlocks}
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Gabarito:wght@400..900&family=Anek+Latin:ital,wght@0,100..800;1,100..800&display=swap" rel="stylesheet" />
  </head>
  <body class="site-body">
    <!-- Skip to main content -->
    <a href="#main-content" class="skip-link">Skip to main content</a>

    <!-- Global topo background overlay -->
    <div class="topo-bg-wrap-fixed">
      <img src="/FallTopo_v2.svg" class="topo-bg" alt="" aria-hidden="true" />
    </div>

    <!-- Navigation -->
    <header class="site-header" id="site-header">
      <div class="header-bg" id="header-bg"></div>
      <nav class="site-nav" aria-label="Primary navigation">
        <!-- Logo (left) -->
        <a href="/" class="nav-logo">
          <div class="nav-logo-icon" role="img" aria-label="Julie Wright Land Company"></div>
        </a>

        {/* Sister site link (right) — hidden for now, kept for later. See `.nav-sister` in global.css.
        <a
          href="https://jwrgnc.com"
          class="nav-sister ml-auto"
          aria-label="Switch to Julie Wright Realty Group"
          rel="noopener"
        >
          <span class="nav-sister-label">Switch to</span>
          <img src="/JWRG_Icon_Horizontal.svg" alt="Julie Wright Realty Group" class="nav-sister-icon" />
          <span class="nav-sister-chevron" aria-hidden="true">&rsaquo;</span>
        </a>
        */}

        <!-- Desktop Nav (center) -->
        <ul class="nav-desktop">
          {navLinks.map((link) => {
            const isActive = currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href));
            return (
              <li>
                <a
                  href={link.href}
                  class:list={[
                    'nav-desktop-link',
                    isActive ? 'nav-link-active' : 'nav-link-inactive',
                  ]}
                  aria-current={isActive ? 'page' : undefined}
                >
                  <span class="nav-link-bg" aria-hidden="true"></span>
                  {link.label}
                  {isActive && <span class="nav-active-bar" />}
                </a>
              </li>
            );
          })}
        </ul>

        <!-- Mobile Menu Button -->
        <button class="mobile-menu-btn" id="mobile-menu-btn" aria-label="Toggle navigation menu" aria-expanded="false" aria-controls="mobile-menu">
          <span class="sr-only">Menu</span>
          <div class="hamburger-wrap" aria-hidden="true">
            <span class="hamburger-bar" id="bar1"></span>
            <span class="hamburger-bar" id="bar2"></span>
            <span class="hamburger-bar" id="bar3"></span>
          </div>
        </button>
      </nav>

      <!-- Mobile Menu -->
      <div class="mobile-menu" id="mobile-menu" aria-hidden="true">
        <ul class="mobile-menu-list">
          {navLinks.map((link) => {
            const isActive = currentPath === link.href;
            return (
              <li>
                <a
                  href={link.href}
                  class:list={[
                    'mobile-menu-link',
                    isActive ? 'nav-link-active' : 'nav-link-inactive',
                  ]}
                  aria-current={isActive ? 'page' : undefined}
                >
                  {link.label}
                </a>
              </li>
            );
          })}
        </ul>
      </div>
    </header>

    <FontSwitcher />

    <!-- Main Content -->
    <main class="site-main" id="main-content">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="site-footer">
      <img src="/FallTopo_v2.svg" class="topo-bg topo-bg--faint" alt="" aria-hidden="true" />
      <div class="footer-inner">
        <div class="footer-grid">
          <!-- Brand -->
          <div class="footer-brand">
            <a href="/" class="footer-logo">
              <img src="/JWLC_Full_Positive.svg" class="footer-logo-img" alt="Julie Wright Land Company" />
            </a>
            <p class="footer-tagline">
              Specializing in Triangle area land brokerage, sales, and investment properties for over 50 years.
            </p>

            <!-- Affiliation / compliance marks (Equal Housing Opportunity + REALTOR®).
                 Single-color official SVGs recolored to the footer palette via CSS mask —
                 source files live in jw-design-guide (public/affiliations/). -->
            <div class="footer-affiliations">
              <span class="footer-affiliation" role="img" aria-label="Equal Housing Opportunity">
                <span class="footer-affiliation-mark footer-affiliation-mark--eho"></span>
              </span>
              <span class="footer-affiliation" role="img" aria-label="REALTOR&reg;">
                <span class="footer-affiliation-mark footer-affiliation-mark--realtor"></span>
              </span>
            </div>
          </div>

          <!-- Quick Links -->
          <nav aria-label="Footer navigation">
            <h4 class="footer-col-heading">Navigate</h4>
            <ul class="footer-nav-list">
              {navLinks.map((link) => (
                <li>
                  <a href={link.href} class="footer-nav-link">{link.label}</a>
                </li>
              ))}
            </ul>
          </nav>

          <!-- Services -->
          <div>
            <h4 class="footer-col-heading">Services</h4>
            <ul class="footer-services-list">
              <li>Land Brokerage & Sales</li>
              <li>Appraisal Services</li>
              <li>Land Planning</li>
              <li>Estate Sales</li>
              <li>1031 Exchanges</li>
              <li>Timber Management</li>
            </ul>
          </div>

          <!-- Contact -->
          <div>
            <h4 class="footer-col-heading">Contact</h4>
            <address class="footer-contact">
              <p>10931 Strickland Rd, Suite 111<br />Raleigh, NC 27615</p>
              <p>
                <a href="tel:9198475731" class="footer-contact-link">(919) 847-5731</a>
              </p>
              <p>
                <a href="mailto:info@juliewrightlandcompany.com" class="footer-contact-link">info@juliewrightlandcompany.com</a>
              </p>
            </address>
          </div>
        </div>

        <div class="footer-bottom">
          <p class="footer-copyright">&copy; {new Date().getFullYear()} Julie Wright Land Company. All rights reserved.</p>
          <p class="footer-location">Raleigh, NC &middot; Serving the Triangle for 50+ Years</p>
        </div>
      </div>
    </footer>

    <script>
      // Topo width — zoom-independent
      // outerWidth is in layout pixels (unaffected by zoom); innerWidth is in CSS pixels (zoom-dependent).
      // We size the SVG in layout pixels, then convert to CSS pixels so it stays physically constant.
      function updateTopoWidth() {
        const outer = window.outerWidth;
        const inner = window.innerWidth;
        const physicalW = Math.max(2160, outer / 0.95); // layout pixels
        const cssW = physicalW * inner / outer;          // convert to CSS pixels
        document.documentElement.style.setProperty('--topo-width', `${Math.round(cssW)}px`);
      }
      let resizeTimer: ReturnType<typeof setTimeout> | null = null;
      function scheduleResize() {
        if (!resizeTimer) {
          document.querySelectorAll<HTMLElement>('.topo-bg').forEach(el => el.style.visibility = 'hidden');
        }
        clearTimeout(resizeTimer!);
        resizeTimer = setTimeout(() => {
          updateTopoWidth();
          updateParallax();
          document.querySelectorAll<HTMLElement>('.topo-bg').forEach(el => el.style.visibility = '');
          resizeTimer = null;
        }, 150);
      }

      updateTopoWidth();
      window.addEventListener('resize', scheduleResize);

      // Topo SVG parallax — seamless across sections, scrolls slower than page
      const PARALLAX_SPEED = 0.3; // fraction of scroll speed (0 = with page, 1 = fixed to viewport)
      function updateParallax() {
        const scrollY = window.scrollY;
        const vpH = window.innerHeight;
        const elements = document.querySelectorAll<HTMLElement>('.topo-bg');
        if (!elements.length) return;

        const svgHeight = elements[0].offsetHeight;

        // Raw target: SVG center drifts upward at PARALLAX_SPEED as page scrolls
        const rawTargetVpY = vpH / 2 - scrollY * PARALLAX_SPEED;

        // Clamp so SVG edges never become visible:
        //   top edge clamped: targetVpY <= svgHeight / 2
        //   bottom edge clamped: targetVpY >= vpH - svgHeight / 2
        const targetVpY = Math.max(vpH - svgHeight / 2, Math.min(svgHeight / 2, rawTargetVpY));

        elements.forEach(el => {
          const section = el.parentElement;
          if (!section) return;
          const rect = section.getBoundingClientRect();
          const sectionCenterVpY = rect.top + rect.height / 2;
          const offset = targetVpY - sectionCenterVpY;
          el.style.transform = `translateX(-50%) translateY(calc(-50% + ${offset}px))`;
        });
      }

      let rafPending = false;
      function scheduleParallax() {
        if (!rafPending) {
          rafPending = true;
          requestAnimationFrame(() => { updateParallax(); rafPending = false; });
        }
      }

      updateParallax();
      window.addEventListener('scroll', scheduleParallax, { passive: true });

      // Nav click animations
      document.querySelectorAll<HTMLAnchorElement>('.nav-desktop-link').forEach(link => {
        link.addEventListener('click', (e) => {
          e.preventDefault();

          // Deactivate current active link
          const activeLink = document.querySelector<HTMLElement>('.nav-link-active');
          if (activeLink && activeLink !== link) {
            activeLink.classList.add('nav-link-deactivating');
          }

          // Drive click animation via inline styles so hover/CSS specificity can't interfere
          const bg = link.querySelector<HTMLElement>('.nav-link-bg');
          if (bg) {
            // Snap to start state (scaleY 0, red, no transition)
            bg.style.transition = 'none';
            bg.style.backgroundColor = 'var(--color-red-600)';
            bg.style.transform = 'scaleY(0)';
            bg.style.opacity = '1';
            // Next frame: re-enable transition and animate to full height
            requestAnimationFrame(() => {
              bg.style.transition = 'transform 100ms ease';
              bg.style.transform = 'scaleY(1)';
            });
          }

          link.classList.add('nav-link-clicking');
          setTimeout(() => { window.location.href = link.href; }, 100);
        });
      });

      // Mobile menu
      const menuBtn = document.getElementById('mobile-menu-btn');
      const mobileMenu = document.getElementById('mobile-menu');

      menuBtn?.addEventListener('click', () => {
        const open = menuBtn.classList.toggle('open');
        mobileMenu?.classList.toggle('open', open);
        menuBtn.setAttribute('aria-expanded', String(open));
        mobileMenu?.setAttribute('aria-hidden', String(!open));
      });
    </script>
  </body>
</html>
