---
import '../styles/global.css';
import FontSwitcher from '../components/FontSwitcher.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Julie Wright Land Company',
  description = 'Specializing in Raleigh, NC and Triangle Area land brokerage, sales, and investment properties for over 40 years.',
} = Astro.props;

const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/listings', label: 'Listings' },
  { href: '/services', label: 'Services' },
  { href: '/testimonials', label: 'Testimonials' },
  { href: '/contact', label: 'Contact' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/JWLC_Icon_3D.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Jost:ital,wght@0,100..900;1,100..900&family=Funnel+Sans:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet" />
  </head>
  <body class="site-body">
    <!-- Navigation -->
    <header class="site-header" id="site-header">
      <div class="header-bg" id="header-bg"></div>
      <nav class="site-nav">
        <!-- Logo (left) -->
        <a href="/" class="nav-logo">
          <div class="nav-logo-icon" role="img" aria-label="Julie Wright Land Company"></div>
        </a>

        <!-- Desktop Nav (center) -->
        <ul class="nav-desktop">
          {navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class:list={[
                  'nav-desktop-link',
                  (currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href)))
                    ? 'nav-link-active'
                    : 'nav-link-inactive',
                ]}
              >
                {link.label}
                {(currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))) && (
                  <span class="nav-active-bar" />
                )}
              </a>
            </li>
          ))}
        </ul>

        <!-- Mobile Menu Button -->
        <button class="mobile-menu-btn" id="mobile-menu-btn" aria-label="Toggle navigation menu">
          <span class="sr-only">Menu</span>
          <div class="hamburger-wrap">
            <span class="hamburger-bar" id="bar1"></span>
            <span class="hamburger-bar" id="bar2"></span>
            <span class="hamburger-bar" id="bar3"></span>
          </div>
        </button>
      </nav>

      <!-- Mobile Menu -->
      <div class="mobile-menu" id="mobile-menu">
        <ul class="mobile-menu-list">
          {navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class:list={[
                  'mobile-menu-link',
                  currentPath === link.href ? 'nav-link-active' : 'nav-link-inactive',
                ]}
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </header>

    <FontSwitcher />

    <!-- Main Content -->
    <main class="site-main">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="site-footer">
      <img src="/FallsLakeTopoContours.svg" class="topo-bg topo-bg--faint" alt="" aria-hidden="true" />
      <div class="footer-inner">
        <div class="footer-grid">
          <!-- Brand -->
          <div class="footer-brand">
            <a href="/" class="footer-logo">
              <img src="/JWLC_Full_Negative.svg" class="footer-logo-img" alt="Julie Wright Land Company" />
            </a>
            <p class="footer-tagline">
              Specializing in Triangle area land brokerage, sales, and investment properties for over 40 years.
            </p>
          </div>

          <!-- Quick Links -->
          <div>
            <h4 class="footer-col-heading">Navigate</h4>
            <ul class="footer-nav-list">
              {navLinks.map((link) => (
                <li>
                  <a href={link.href} class="footer-nav-link">{link.label}</a>
                </li>
              ))}
            </ul>
          </div>

          <!-- Services -->
          <div>
            <h4 class="footer-col-heading">Services</h4>
            <ul class="footer-services-list">
              <li>Land Brokerage & Sales</li>
              <li>Appraisal Services</li>
              <li>Land Planning</li>
              <li>Estate Sales</li>
              <li>1031 Exchanges</li>
              <li>Timber Management</li>
            </ul>
          </div>

          <!-- Contact -->
          <div>
            <h4 class="footer-col-heading">Contact</h4>
            <address class="footer-contact">
              <p>10931 Strickland Rd, Suite 111<br />Raleigh, NC 27615</p>
              <p>
                <a href="tel:9198475731" class="footer-contact-link">(919) 847-5731</a>
              </p>
              <p>
                <a href="mailto:juliannawright@gmail.com" class="footer-contact-link">juliannawright@gmail.com</a>
              </p>
            </address>
          </div>
        </div>

        <div class="footer-bottom">
          <p class="footer-copyright">&copy; {new Date().getFullYear()} Julie Wright Land Company. All rights reserved.</p>
          <p class="footer-location">Raleigh, NC &middot; Serving the Triangle for 40+ Years</p>
        </div>
      </div>
    </footer>

    <script>
      // Topo SVG parallax
      function updateParallax() {
        document.querySelectorAll('.topo-bg').forEach(el => {
          const section = el.parentElement;
          if (!section) return;
          const rect = section.getBoundingClientRect();
          const relativeToCenter = rect.top + rect.height / 2 - window.innerHeight / 2;
          const offset = -relativeToCenter;
          el.style.transform = `translateX(-50%) translateY(calc(-50% + ${offset}px))`;
        });
      }

      updateParallax();
      window.addEventListener('scroll', updateParallax, { passive: true });

      // Mobile menu
      const menuBtn = document.getElementById('mobile-menu-btn');
      const mobileMenu = document.getElementById('mobile-menu');

      menuBtn?.addEventListener('click', () => {
        const open = menuBtn.classList.toggle('open');
        mobileMenu?.classList.toggle('open', open);
      });
    </script>
  </body>
</html>
