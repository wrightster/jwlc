---
// Server island (used with `server:defer`): the home "Current Listings" strip,
// live from the office API. Deferring it lets the home shell (hero + about/
// services + CTA) prerender and paint instantly; the strip streams in behind its
// skeleton fallback. No client script here (the hero-quote rotator stays on the
// page, untouched — it drives the hero, not this strip). See the listings page
// for the script-in-island caveat (withastro/astro#12294).
import ListingCard from './ListingCard.astro';
import { fetchAllListings, type ApiListing } from '../lib/api';

let apiError = false;
let allListings: ApiListing[] = [];
try {
  allListings = await fetchAllListings();
} catch {
  apiError = true;
}
const featuredListings = allListings.filter(l => l.featured);
---

{apiError ? (
  <p class="text-earth-600 text-center py-8">Listings are temporarily unavailable — please try again shortly.</p>
) : (
  <div class="featured-grid">
    {featuredListings.slice(0, 3).map((listing, i) => (
      <ListingCard listing={listing} index={i} />
    ))}
  </div>
)}
