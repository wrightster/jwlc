---
// Server island (used with `server:defer`): the listings filter chrome + results
// grid, rendered live from the office API. Deferring it lets the /listings shell
// prerender and paint instantly (banner + CTA), then this data section streams in
// behind its skeleton fallback.
//
// IMPORTANT: there is NO client `<script>` in this island. The interactive
// controller (custom selects, sliders, pagination, view toggle, URL sync) lives
// on the page (listings.astro) and initializes once this island's content
// arrives, detected via the `data-listings-ready` sentinel below. Scripts placed
// inside a server island run unreliably (withastro/astro#12294), so the
// DOM-querying controller must stay on the host page.
import ListingCard from './ListingCard.astro';
import ListingRow from './ListingRow.astro';
import { fetchAllListings, type ApiListing } from '../lib/api';

let apiError = false;
let listings: ApiListing[] = [];
try {
  listings = await fetchAllListings();
} catch {
  apiError = true;
}

const counties = [...new Set(listings.map(l => l.county))].sort();
const cities   = [...new Set(listings.map(l => l.city))].sort();
---

{apiError ? (
  <div class="py-16 text-center" data-listings-ready="error">
    <p class="text-earth-700">Our listings are temporarily unavailable — please try again shortly.</p>
    <p class="text-earth-500 text-sm mt-2">Or <a href="/contact" class="text-red-600 underline underline-offset-2">contact us</a> directly and we'll be happy to help.</p>
  </div>
) : (
  <div class="contents" data-listings-ready="ok">
    <!-- Filter bar -->
    <div class="filter-bar" id="filter-bar">
      <button class="filter-toggle-btn" id="filter-toggle" type="button" aria-expanded="false" aria-controls="filter-collapse">
        <svg class="filter-toggle-icon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/></svg>
        <span class="filter-toggle-label">Filters</span>
        <span class="filter-toggle-count" id="filter-active-count" aria-live="polite"></span>
        <svg class="filter-toggle-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
      </button>
      <div class="filter-collapse" id="filter-collapse">
        <div class="filter-collapse-inner">
          <div class="filter-controls-row">

        <!-- County dropdown -->
        <div class="filter-select-wrap">
          <span class="filter-select-label">County</span>
          <div class="custom-select" data-filter="county">
            <button class="custom-select-trigger" type="button" aria-haspopup="listbox" aria-expanded="false">
              <span class="custom-select-val">All Counties</span>
              <svg class="custom-select-chevron" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <ul class="custom-select-list" role="listbox">
              <li class="custom-select-option is-selected" data-value="all" role="option" aria-selected="true">All Counties</li>
              {counties.map((county) => (
                <li class="custom-select-option" data-value={county} role="option" aria-selected="false">{county}</li>
              ))}
            </ul>
          </div>
        </div>

        <!-- City dropdown -->
        <div class="filter-select-wrap">
          <span class="filter-select-label">City</span>
          <div class="custom-select" data-filter="city">
            <button class="custom-select-trigger" type="button" aria-haspopup="listbox" aria-expanded="false">
              <span class="custom-select-val">All Cities</span>
              <svg class="custom-select-chevron" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <ul class="custom-select-list" role="listbox">
              <li class="custom-select-option is-selected" data-value="all" role="option" aria-selected="true">All Cities</li>
              {cities.map((city) => (
                <li class="custom-select-option" data-value={city} role="option" aria-selected="false">{city}</li>
              ))}
            </ul>
          </div>
        </div>

        <!-- Status dropdown -->
        <div class="filter-select-wrap">
          <span class="filter-select-label">Status</span>
          <div class="custom-select" data-filter="status">
            <button class="custom-select-trigger" type="button" aria-haspopup="listbox" aria-expanded="false">
              <span class="custom-select-val">All Statuses</span>
              <svg class="custom-select-chevron" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <ul class="custom-select-list" role="listbox">
              <li class="custom-select-option is-selected" data-value="all" role="option" aria-selected="true">All Statuses</li>
              <li class="custom-select-option" data-value="active" role="option" aria-selected="false">Available</li>
              <li class="custom-select-option" data-value="coming_soon" role="option" aria-selected="false">Coming Soon</li>
              <li class="custom-select-option" data-value="pending" role="option" aria-selected="false">Pending</li>
              <li class="custom-select-option" data-value="under_contract" role="option" aria-selected="false">Under Contract</li>
              <li class="custom-select-option" data-value="sold" role="option" aria-selected="false">Sold</li>
            </ul>
          </div>
        </div>

        <!-- Price slider -->
        <div class="filter-range-wrap">
          <p class="filter-select-label" id="price-range-label">Price Range</p>
          <div class="range-slider">
            <div class="range-track"><div class="range-fill" id="price-fill"></div></div>
            <input type="range" id="price-min" min="0" max="500000" step="10000" value="0" class="range-input" aria-label="Minimum price" aria-labelledby="price-range-label" />
            <input type="range" id="price-max" min="0" max="500000" step="10000" value="500000" class="range-input" aria-label="Maximum price" />
          </div>
          <div class="filter-range-display" aria-hidden="true">
            <span id="price-min-display" class="filter-range-val">$0</span>
            <span class="filter-range-sep">–</span>
            <span id="price-max-display" class="filter-range-val">$500,000+</span>
          </div>
        </div>

        <!-- Acreage slider -->
        <div class="filter-range-wrap">
          <p class="filter-select-label" id="acres-range-label">Acreage</p>
          <div class="range-slider">
            <div class="range-track"><div class="range-fill" id="acres-fill"></div></div>
            <input type="range" id="acres-min" min="0" max="50" step="1" value="0" class="range-input" aria-label="Minimum acreage" aria-labelledby="acres-range-label" />
            <input type="range" id="acres-max" min="0" max="50" step="1" value="50" class="range-input" aria-label="Maximum acreage" />
          </div>
          <div class="filter-range-display" aria-hidden="true">
            <span id="acres-min-display" class="filter-range-val">0</span>
            <span class="filter-range-sep">–</span>
            <span id="acres-max-display" class="filter-range-val">50+ ac</span>
          </div>
        </div>

          </div>
        </div>
      </div>
    </div>

    <!-- Results count + per-page + view toggle -->
    <div class="results-bar">
      <p class="results-count" id="results-count" aria-live="polite" aria-atomic="true">
        Showing <span class="results-count-val">{listings.length}</span> propert{listings.length === 1 ? 'y' : 'ies'}
      </p>
      <div class="per-page-select">
        <span class="per-page-label">Per page</span>
        {([12, 24, 48, 96] as const).map(n => (
          <button class:list={['per-page-btn', n === 24 && 'is-active']} data-pp={n} type="button">{n}</button>
        ))}
      </div>
      <div class="view-toggle" id="view-toggle" aria-label="Toggle view">
        <button class="view-toggle-btn is-active" id="btn-grid" type="button" aria-label="Grid view" title="Grid view">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <rect x="3" y="3" width="8" height="8" rx="1"/><rect x="13" y="3" width="8" height="8" rx="1"/>
            <rect x="3" y="13" width="8" height="8" rx="1"/><rect x="13" y="13" width="8" height="8" rx="1"/>
          </svg>
        </button>
        <button class="view-toggle-btn" id="btn-list" type="button" aria-label="List view" title="List view">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <rect x="3" y="4" width="18" height="3" rx="1"/><rect x="3" y="10.5" width="18" height="3" rx="1"/><rect x="3" y="17" width="18" height="3" rx="1"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- Listings container -->
    <div class="listings-grid" id="listings-grid">
      {listings.map((listing, i) => (
        <div
          class="listing-item"
          data-county={listing.county}
          data-city={listing.city}
          data-status={listing.status}
          data-price={Math.round(parseFloat(listing.list_price))}
          data-acres={listing.lot_size_acres ? parseFloat(listing.lot_size_acres) : 0}
          id={listing.slug}
        >
          <ListingCard listing={listing} index={i} />
          <ListingRow listing={listing} />
        </div>
      ))}
    </div>

    <!-- Pagination -->
    <div class="pagination" id="pagination" style="display:none">
      <button id="pg-prev" class="pg-btn" type="button" aria-label="Previous page" disabled>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
      </button>
      <span id="pg-info" class="pg-info">Page 1 of 1</span>
      <button id="pg-next" class="pg-btn" type="button" aria-label="Next page">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
      </button>
    </div>
  </div>
)}
