---
import type { Listing } from '../data/listings';
import { getListingImages } from '../data/listings';

interface Props {
  listing: Listing;
  index?: number;
}

const { listing, index = 0 } = Astro.props;
const images = getListingImages(listing);
---

<a href={`/listings/${listing.id}`} class="listing-card">
  <!-- Image Header -->
  <div class="listing-card-image">
    <img src={images[0]} alt={listing.title} class="listing-card-img" loading="lazy" />
    <div class="listing-card-gradient"></div>
    <div class="listing-card-overlay">
      <div>
        <p class="listing-card-county">{listing.county} County</p>
        <p class="listing-card-acreage">{listing.acreage}</p>
      </div>
    </div>
    {images.length > 1 && (
      <span class="listing-card-photos-badge">
        <svg class="listing-card-photos-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.41a2.25 2.25 0 013.182 0l2.909 2.91M3.75 21h16.5a2.25 2.25 0 002.25-2.25V5.25a2.25 2.25 0 00-2.25-2.25H3.75a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 003.75 21z" />
        </svg>
        {images.length}
      </span>
    )}
    <span class="listing-card-status" data-status={listing.status}>
      {listing.status === 'available' ? 'Available' : listing.status === 'pending' ? 'Pending' : 'Sold'}
    </span>
  </div>

  <!-- Content -->
  <div class="listing-card-body">
    <h3 class="listing-card-title">{listing.title}</h3>
    <p class="listing-card-desc">{listing.description}</p>
    <div class="listing-card-footer">
      <span class="listing-card-price">{listing.price}</span>
      <span class="listing-card-link">
        View Details
        <svg class="listing-card-link-arrow" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </span>
    </div>
  </div>
</a>
