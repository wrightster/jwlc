---
// JWLC wrapper over the shared ListingCard: computes the land-focused headline
// (acreage) and forwards everything to @jw/shared. Keep this thin — shared
// markup/classes live in the package.

import SharedListingCard from '@jw/shared/components/ListingCard.astro';
import { formatAcres, type ApiListing } from '../lib/api';

interface Props {
  listing: ApiListing;
  index?: number;
}

const { listing, index } = Astro.props;
const headline = formatAcres(listing.lot_size_acres) || `${listing.city}, ${listing.state}`;
---

<SharedListingCard listing={listing} index={index} headline={headline} />
