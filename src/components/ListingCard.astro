---
import type { Listing } from '../data/listings';
import { getListingImages } from '../data/listings';

interface Props {
  listing: Listing;
  index?: number;
}

const { listing, index = 0 } = Astro.props;
const images = getListingImages(listing);
---

<a
  href={`/listings/${listing.id}`}
  class="group relative block bg-brand-bg rounded-sm overflow-hidden transition-all duration-300 after:absolute after:inset-0 after:rounded-sm after:pointer-events-none after:shadow-[inset_0_0_0_1px_var(--color-brand-light)] after:transition-all after:duration-300 hover:after:shadow-[inset_0_0_0_3px_var(--color-crimson-700)]"
>
  <!-- Image Header -->
  <div class="relative h-48 overflow-hidden bg-earth-200">
    <img
      src={images[0]}
      alt={listing.title}
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-earth-900/50 to-transparent"></div>
    <div class="absolute inset-0 flex items-end p-5">
      <div>
        <p class="text-[11px] uppercase tracking-widest text-white/90 font-semibold mb-0.5">
          {listing.county}
        </p>
        <p class="text-2xl font-display text-white leading-tight">{listing.acreage}</p>
      </div>
    </div>
    {images.length > 1 && (
      <span class="absolute top-4 left-0 inline-flex items-center gap-1.5 pl-4 pr-3 py-1 rounded-r-sm bg-brand-light text-earth-900 text-xs font-semibold uppercase tracking-widest">
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.41a2.25 2.25 0 013.182 0l2.909 2.91M3.75 21h16.5a2.25 2.25 0 002.25-2.25V5.25a2.25 2.25 0 00-2.25-2.25H3.75a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 003.75 21z" />
        </svg>
        {images.length}
      </span>
    )}
    <span class:list={[
      'absolute top-4 right-0 pl-4 pr-4 py-1 rounded-l-sm text-xs font-semibold uppercase tracking-widest',
      listing.status === 'available' ? 'bg-crimson-700 text-brand-bg' :
      listing.status === 'pending'   ? 'bg-brand-medium text-earth-900' :
                                       'bg-earth-900 text-light-text',
    ]}>
      {listing.status === 'available' ? 'Available' : listing.status === 'pending' ? 'Pending' : 'Sold'}
    </span>
  </div>

  <!-- Content -->
  <div class="p-5">
    <h3 class="font-display text-lg text-earth-900 leading-snug mb-2 group-hover:text-crimson-700 transition-colors duration-300">
      {listing.title}
    </h3>
    <p class="text-earth-600 leading-relaxed line-clamp-3 mb-4">
      {listing.description}
    </p>
    <div class="flex items-center justify-between pt-3 border-t border-earth-200">
      <span class="font-display text-xl text-crimson-700">{listing.price}</span>
      <span class="text-xs text-earth-500 flex items-center gap-1 group-hover:text-crimson-700 transition-colors">
        View Details
        <svg class="w-3.5 h-3.5 transform group-hover:translate-x-1 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </span>
    </div>
  </div>
</a>
