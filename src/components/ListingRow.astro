---
// JWLC wrapper over the shared ListingRow: passes the land-focused headline
// (acreage) and forwards to @jw/shared. Keep this thin.

import SharedListingRow from '@jw/shared/components/ListingRow.astro';
import { formatAcres, type ApiListing } from '../lib/api';

interface Props {
  listing: ApiListing;
}

const { listing } = Astro.props;
const headline = formatAcres(listing.lot_size_acres);
---

<SharedListingRow listing={listing} headline={headline} />
