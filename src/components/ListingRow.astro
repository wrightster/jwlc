---
import type { Listing } from '../data/listings';
import { getListingImages } from '../data/listings';

interface Props {
  listing: Listing;
}

const { listing } = Astro.props;
const images = getListingImages(listing);
---

<a href={`/listings/${listing.id}`} class="listing-row">
  <!-- Thumbnail -->
  <div class="listing-row-thumb">
    <img src={images[0]} alt={listing.title} class="listing-row-img" loading="lazy" />
  </div>

  <!-- Content area (everything right of thumb) -->
  <div class="listing-row-content">
    <!-- Main info -->
    <div class="listing-row-body">
      <div class="listing-row-meta">
        <span class="listing-row-status" data-status={listing.status}>
          {listing.status === 'available' ? 'Available' : listing.status === 'pending' ? 'Pending' : 'Sold'}
        </span>
        <span class="listing-row-county">{listing.county} County</span>
      </div>
      <h3 class="listing-row-title">{listing.title}</h3>
    </div>

    <!-- Price + link -->
    <div class="listing-row-right">
      <p class="listing-row-acreage">{listing.acreage}</p>
      <span class="listing-row-price">{listing.price}</span>
      <span class="listing-row-link">
        View Details
        <svg class="listing-row-arrow" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </span>
    </div>
  </div>
</a>
